# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ark_chatbot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ark_chatbot

# ── Chat Provider (generates responses) ──────────────────
CHAT_PROVIDER=gemini                   # gemini | openai | anthropic | ollama
CHAT_MODEL=gemini-2.5-flash
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1024

# ── GCP (required for Gemini via Vertex AI) ──────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Embedding Provider (vector search) ───────────────────
EMBEDDING_PROVIDER=gemini              # gemini | openai | ollama
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# ── Extraction Provider (background memory extraction) ───
# Defaults to CHAT_PROVIDER if empty
EXTRACTION_PROVIDER=
EXTRACTION_MODEL=gemini-2.5-flash
EXTRACTION_TEMPERATURE=0.1
EXTRACTION_MAX_TOKENS=4096
EXTRACTION_MESSAGE_LIMIT=10           # Messages per extraction batch (5 user + 5 assistant)
EXTRACTION_ENTITY_CONTEXT=50          # Existing entities passed for dedup
EXTRACTION_RELATIONSHIP_CONTEXT=30    # Existing relationships passed for dedup
EXTRACTION_RECAP_CONTEXT=7            # Existing recaps passed for dedup

# ── Token Counter ────────────────────────────────────────
TOKEN_COUNTER=tiktoken                 # tiktoken | character_estimate

# ── Context Builder Budget ───────────────────────────────
BUILDER_PERSONA_RATIO=0.10            # System prompt budget (% of total)
BUILDER_PERSONA_MAX=400               # Hard cap on system prompt tokens
BUILDER_RECENT_RATIO=0.50             # Recent messages budget (% of total)
BUILDER_RAG_RATIO=0.40                # RAG/memories budget (% of total)
BUILDER_TOTAL_BUDGET=4000             # Total token budget for context assembly
BUILDER_RECENT_MESSAGES_LIMIT=100     # Max messages loaded from DB

# ── STM (Short-Term Memory) ─────────────────────────────
RECAP_INTERVAL_MESSAGES=5             # Extract memory every N user messages
STM_MAX_ENTITIES=150                  # Max entities per chat
STM_MAX_RELATIONSHIPS=200             # Max relationships per chat
STM_MIN_CONFIDENCE=0.30               # Floor confidence for new entities
STM_MAX_CONFIDENCE=0.95               # Cap confidence (never 1.0)
STM_CONFIDENCE_BOOST=0.20             # Confidence reinforcement on re-mention

# ── RAG Retrieval ────────────────────────────────────────
RAG_SEARCH_TIMEOUT=1.0
RAG_HYBRID_FTS_WEIGHT=0.3             # FTS weight in hybrid scoring
RAG_HYBRID_VECTOR_WEIGHT=0.7          # Vector weight in hybrid scoring
RAG_VECTOR_DISTANCE_THRESHOLD=0.6     # Max cosine distance for vector matches
RAG_MAX_KEYWORDS=10                   # Max keywords extracted from query

# ── RAG Scoring Weights ─────────────────────────────────
RAG_SCORE_HYBRID_WEIGHT=0.4           # Weight for hybrid match score
RAG_SCORE_CONFIDENCE_WEIGHT=0.3       # Weight for entity confidence
RAG_SCORE_RECENCY_WEIGHT=0.3          # Weight for recency score

# ── RAG Retrieval Limits ─────────────────────────────────
RAG_STM_ENTITY_LIMIT=50
RAG_STM_RECAP_LIMIT=10
RAG_STM_RELATIONSHIP_LIMIT=30
RAG_LTM_ENTITY_LIMIT=50
RAG_LTM_EPISODE_LIMIT=20

# ── RAG Episode Budget by Turn Count ────────────────────
RAG_EPISODE_BUDGET_TURN_1_2=0.25      # 25% for first 2 turns
RAG_EPISODE_BUDGET_TURN_3_5=0.15      # 15% for turns 3-5
RAG_EPISODE_BUDGET_TURN_6_19=0.10     # 10% for turns 6-19
RAG_EPISODE_BUDGET_TURN_20_PLUS=0.10  # 10% for 20+ turns

# ── Recency Scoring ─────────────────────────────────────
RECENCY_BASE_HALF_LIFE_HOURS=72       # 3-day base half-life
RECENCY_MENTION_FACTOR=0.2            # Per-mention multiplier for half-life
RECENCY_MENTION_CAP=5                 # Max mentions factored into decay
RECENCY_CONFIDENCE_FACTOR=0.5         # Confidence contribution to half-life

# ── LTM Episodes ────────────────────────────────────────
EPISODE_INTERVAL_MESSAGES=20          # Chunk episode every N user messages
FINAL_EPISODE_MIN_MESSAGES=2          # Min user messages to generate episode
EPISODE_RETRIEVAL_LIMIT=5             # Top episodes per RAG search
EPISODE_DECAY_HALF_LIFE_DAYS=7        # Importance decay half-life
EPISODE_MAX_TOKENS=1000               # Max tokens for episode LLM call
EPISODE_MESSAGES_CONTEXT=10           # Recent messages fed to episode generation
EPISODE_ENTITIES_CONTEXT=50           # Max entities fed to episode generation
EPISODE_RELATIONSHIPS_CONTEXT=30      # Max relationships fed to episode generation

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Alternative: OpenAI ──────────────────────────────────
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Alternative: Anthropic ───────────────────────────────
# CHAT_PROVIDER=anthropic
# CHAT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Alternative: Ollama (local) ──────────────────────────
# CHAT_PROVIDER=ollama
# CHAT_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
