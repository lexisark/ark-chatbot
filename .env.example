# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ark_chatbot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ark_chatbot

# ── Chat Provider (generates responses) ──────────────────
CHAT_PROVIDER=gemini                   # gemini | openai | anthropic | ollama
CHAT_MODEL=gemini-2.5-flash

# ── GCP (required for Gemini via Vertex AI) ──────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Embedding Provider (vector search) ───────────────────
EMBEDDING_PROVIDER=gemini              # gemini | openai | ollama
EMBEDDING_MODEL=gemini-embedding-001

# ── Extraction Provider (background memory extraction) ───
# Defaults to CHAT_PROVIDER if empty
EXTRACTION_PROVIDER=
EXTRACTION_MODEL=gemini-2.5-flash
EXTRACTION_TEMPERATURE=0.1

# ── Token Counter ────────────────────────────────────────
TOKEN_COUNTER=tiktoken                 # tiktoken | character_estimate

# ── Context Builder Budget ───────────────────────────────
BUILDER_PERSONA_RATIO=0.10
BUILDER_PERSONA_MAX=400
BUILDER_RECENT_RATIO=0.50
BUILDER_RAG_RATIO=0.40
BUILDER_TOTAL_BUDGET=4000

# ── STM Extraction ───────────────────────────────────────
RECAP_INTERVAL_MESSAGES=5
STM_MAX_ENTITIES=150
STM_MAX_RELATIONSHIPS=200
STM_MIN_CONFIDENCE=0.30
STM_FACT_BOOST=0.20

# ── RAG Retrieval ────────────────────────────────────────
RAG_SEARCH_TIMEOUT=1.0
RAG_HYBRID_FTS_WEIGHT=0.7
RAG_HYBRID_VECTOR_WEIGHT=0.3
RAG_EPISODE_BUDGET_EARLY=0.25
RAG_EPISODE_BUDGET_MID=0.15
RAG_EPISODE_BUDGET_LATE=0.10
RAG_VECTOR_DISTANCE=0.6

# ── LTM Episodes ────────────────────────────────────────
EPISODE_INTERVAL_MESSAGES=20
FINAL_EPISODE_MIN_MESSAGES=3
EPISODE_RETRIEVAL_LIMIT=5

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Alternative: OpenAI ──────────────────────────────────
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Alternative: Anthropic ───────────────────────────────
# CHAT_PROVIDER=anthropic
# CHAT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── Alternative: Ollama (local) ──────────────────────────
# CHAT_PROVIDER=ollama
# CHAT_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
